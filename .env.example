# Configurações do QualitiOS

# Portas de Rede expostas no Host
QUALITI_FRONTEND_PORT=3002
QUALITI_PORT=3001
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Chaves de Segurança e Secrets (Devem ser alteradas em Produção)
JWT_SECRET=super_secret_qualita_jwt_key_2026_secure

# Conexão com o Banco de Dados Compartilhado
DATABASE_URL=postgres://qualita:qualita_secure_pw@shared-postgres:5432/qualitaos

# Configurações de Inteligência Artificial e LLM
AI_API_KEY=mock_key_for_simulation
AI_PROVIDER=mock
OLLAMA_URL=http://shared-ollama:11434
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3002
